objects":[{"assetStoreId":"fe58defcf508279eb83802ec7d49c91febab9ebf9b63284e70eb08551c6d1fb4","name":"Historia","persistentUuid":"9bc84abd-c01e-4360-8fbc-832ec2233ec9","type":"BitmapText::BitmapTextObject","variables":[],"effects":[],"behaviors":[],"content":{"text":"Em um mundo que antes vivia em equilibrio com a natureza, a poluicao comecou a se espalhar por florestas, rios e montanhas, consumindo a energia vital que mantinha todas as formas de vida em harmonia. Com o avanco dessa destruicao, o Cristal da Vida, uma reliquia sagrada responsavel por sustentar o equilibrio natural do mundo, foi rompido, espalhando seus fragmentos por diferentes regioes agora corrompidas.","opacity":255.0,"scale":3.0,"fontSize":20.0,"tint":"255;255;255","bitmapFontResourceName":"assets/NotJamSignature21.fnt","textureAtlasResourceName":"assets/NotJamSignature21.png","align":"left","verticalTextAlignment":"top"}},{"assetStoreId":"fe58defcf508279eb83802ec7d49c91febab9ebf9b63284e70eb08551c6d1fb4","name":"Historia2","persistentUuid":"0d65c8a5-6110-4fba-8e5b-7c92fd648288","type":"BitmapText::BitmapTextObject","variables":[],"effects":[],"behaviors":[],"content":{"text":"Sem a protecao do cristal, a natureza perdeu sua estabilidade. Criaturas que antes coexistiam em paz com o ambiente passaram a agir de forma hostil, transformadas pela contaminacao e pela ausencia da energia sagrada. Alem disso, os caminhos naturais foram afetados pela degradacao, fazendo surgir perigos e obstaculos ao longo da jornada, como areas instaveis, espinhos e passagens bloqueadas.","opacity":255.0,"scale":3.0,"fontSize":20.0,"tint":"255;255;255","bitmapFontResourceName":"assets/NotJamSignature21.fnt","textureAtlasResourceName":"assets/NotJamSignature21.png","align":"left","verticalTextAlignment":"top"}},{"assetStoreId":"","bottomMargin":0.0,"height":32.0,"leftMargin":0.0,"name":"Pergaminho","persistentUuid":"e0712913-929e-405b-90b9-1f24d9e211c8","rightMargin":0.0,"texture":"assets/pergaminho.png","tiled":false,"topMargin":0.0,"type":"PanelSpriteObject::PanelSprite","width":32.0,"variables":[],"effects":[],"behaviors":[]},{"assetStoreId":"fe58defcf508279eb83802ec7d49c91febab9ebf9b63284e70eb08551c6d1fb4","name":"Historia3","persistentUuid":"a7f0a3f6-5be4-44a6-a603-a547c872698d","type":"BitmapText::BitmapTextObject","variables":[],"effects":[],"behaviors":[],"content":{"text":"Diante desse cenario, o protagonista parte em uma missao para recuperar os fragmentos do Cristal da Vida e devolve-los a natureza. Durante a aventura, ele deve atravessar regioes tomadas pela poluicao e reativar antigos mecanismos esquecidos, como alavancas que liberam plataformas e restabelecem a passagem por areas bloqueadas.","opacity":255.0,"scale":3.0,"fontSize":20.0,"tint":"255;255;255","bitmapFontResourceName":"assets/NotJamSignature21.fnt","textureAtlasResourceName":"assets/NotJamSignature21.png","align":"left","verticalTextAlignment":"top"}},{"assetStoreId":"fe58defcf508279eb83802ec7d49c91febab9ebf9b63284e70eb08551c6d1fb4","name":"Historia4","persistentUuid":"867284c9-9dd0-4dd9-8f80-ab02e2a04c12","type":"BitmapText::BitmapTextObject","variables":[],"effects":[],"behaviors":[],"content":{"text":"Nesta jornada, o heroi encontra dois tipos de itens fundamentais: as macas, que simbolizam a força regeneradora da propria natureza e ajudam a restaurar sua vitalidade, e as moedas, que representam tesouros perdidos nas areas corrompidas. Diferente da energia vital, as moedas servem como um registro das conquistas do heroi, sendo acumuladas para compor sua pontuacao final ao concluir o objetivo de salvar o mundo.","opacity":255.0,"scale":3.0,"fontSize":20.0,"tint":"255;255;255","bitmapFontResourceName":"assets/NotJamSignature21.fnt","textureAtlasResourceName":"assets/NotJamSignature21.png","align":"left","verticalTextAlignment":"top"}},{"adaptCollisionMaskAutomatically":true,"assetStoreId":"d51e51b54699cc452f0a31d1bae5e3816c3a3017ebf3e2ddb76cbcf2fbe9b698","name":"Botao_DIreita","persistentUuid":"7c417208-183f-45f3-9180-44b7010f1776","type":"Sprite","updateIfNotVisible":false,"variables":[],"effects":[],"behaviors":[],"animations":[{"name":"","useMultipleDirections":false,"directions":[{"looping":true,"timeBetweenFrames":0.025,"sprites":[{"hasCustomCollisionMask":true,"image":"Right-Arrow.png","points":[],"originPoint":{"name":"origine","x":0.0,"y":0.0},"centerPoint":{"automatic":true,"name":"centre","x":0.0,"y":0.0},"customCollisionMask":[[{"x":0.0,"y":0.0},{"x":14.0,"y":0.0},{"x":14.0,"y":14.0},{"x":0.0,"y":14.0}]]}]}]}]},{"adaptCollisionMaskAutomatically":true,"assetStoreId":"13a9cef806e970f1b9426f37cf41e27eb70fffedac02cd4736c023201afb7011","name":"Botao_Esquerda","persistentUuid":"43fd9757-e956-4323-af17-a5216b80215a","type":"Sprite","updateIfNotVisible":false,"variables":[],"effects":[],"behaviors":[],"animations":[{"name":"","useMultipleDirections":false,"directions":[{"looping":true,"timeBetweenFrames":0.025,"sprites":[{"hasCustomCollisionMask":true,"image":"Left-Arrow.png","points":[],"originPoint":{"name":"origine","x":0.0,"y":0.0},"centerPoint":{"automatic":true,"name":"centre","x":0.0,"y":0.0},"customCollisionMask":[[{"x":0.0,"y":0.0},{"x":14.0,"y":0.0},{"x":14.0,"y":14.0},{"x":0.0,"y":14.0}]]}]}]}]},{"assetStoreId":"fe58defcf508279eb83802ec7d49c91febab9ebf9b63284e70eb08551c6d1fb4","name":"Historia5","persistentUuid":"a3eb3b8d-727a-40cd-803e-dd1f29e8d145","type":"BitmapText::BitmapTextObject","variables":[],"effects":[],"behaviors":[],"content":{"text":"O momento de maior importancia ocorre ao final de cada regiao. Antes de atravessar a porta que leva ao proximo desafio, o heroi deve coletar uma porcao concentrada da energia do Cristal. Esse ato simboliza a purificacao daquela area e garante ao protagonista a força necessaria para avançar. Assim, cada fase superada representa um passo crucial na reconstrucao do Cristal da Vida e na esperanca de devolver ao mundo a pureza que a poluicao quase destruiu por completo.","opacity":255.0,"scale":3.0,"fontSize":20.0,"tint":"255;255;255","bitmapFontResourceName":"assets/NotJamSignature21.fnt","textureAtlasResourceName":"assets/NotJamSignature21.png","align":"left","verticalTextAlignment":"top"}}],"objectsFolderStructure":{"folderName":"__ROOT","children":[{"objectName":"Historia"},{"objectName":"Historia2"},{"objectName":"Historia3"},{"objectName":"Historia4"},{"objectName":"Historia5"},{"objectName":"Pergaminho"},{"objectName":"Botao_Esquerda"},{"objectName":"Botao_DIreita"}]},"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["IndiceHistoria","=","1"]}],"actions":[{"type":{"value":"Hide"},"parameters":["Botao_Esquerda"]},{"type":{"value":"Hide"},"parameters":["Historia2"]},{"type":{"value":"Hide"},"parameters":["Historia3"]},{"type":{"value":"Hide"},"parameters":["Historia4"]},{"type":{"value":"Hide"},"parameters":["Historia5"]},{"type":{"value":"Show"},"parameters":["Historia",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["IndiceHistoria","=","2"]}],"actions":[{"type":{"value":"Hide"},"parameters":["Historia"]},{"type":{"value":"Hide"},"parameters":["Historia3"]},{"type":{"value":"Hide"},"parameters":["Historia4"]},{"type":{"value":"Hide"},"parameters":["Historia5"]},{"type":{"value":"Show"},"parameters":["Botao_Esquerda",""]},{"type":{"value":"Show"},"parameters":["Historia2",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["IndiceHistoria","=","3"]}],"actions":[{"type":{"value":"Hide"},"parameters":["Historia"]},{"type":{"value":"Hide"},"parameters":["Historia2"]},{"type":{"value":"Hide"},"parameters":["Historia4"]},{"type":{"value":"Hide"},"parameters":["Historia5"]},{"type":{"value":"Show"},"parameters":["Historia3",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["IndiceHistoria","=","4"]}],"actions":[{"